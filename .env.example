PORT=3333
DASHBOARD_TOKEN=tajny-token-prezesa
AGENTS_DIR=/home/openclaw/agents
OPENCLAW_STATE_DIR=/home/openclaw/.openclaw/agents
AGENT_NAMES=patrykg,annag,paulinag,katarzynag,katarzynac

# Ollama AI Analysis
OLLAMA_URL=http://10.0.1.1:11434
OLLAMA_MODEL=gemma3:12b
ANALYSIS_TIMEOUT=600000
ANALYSIS_DATA_DIR=/data/analysis
DB_PATH=/data/dashboard.db
ANALYSIS_CRON_HOUR=3
ANALYSIS_CRON_MINUTE=0
ANALYSIS_CRON_ENABLED=true

# OpenRouter pricing (for accurate cost estimation when provider=openrouter)
# Default model for 'openrouter/auto' cost calculation
OPENROUTER_DEFAULT_MODEL=google/gemini-3-flash-preview

# OpenRouter Management Key (for Activity API — real cost reconciliation)
# Create at: openrouter.ai → Settings → API Keys → Management Key
OPENROUTER_MGMT_KEY=
